{
  "name": "scemas-platform",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "db:push": "if [ -f .env ]; then set -a && . ./.env && set +a; fi; bun --filter @scemas/db push && bun --filter @scemas/db ensure-users",
    "db:generate": "bun --filter @scemas/db generate",
    "db:studio": "bun --filter @scemas/db studio",
    "seed": "bun run scripts/seed.ts"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  }
}
